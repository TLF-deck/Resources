<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;700&display=swap');

  :root {
    --ink:        #1a1a2e;
    --teal:       #16697a;
    --teal-light: #d0ecf1;
    --teal-mid:   #9fd3dc;
    --amber:      #e6a817;
    --amber-light:#fdf3d9;
    --smoke:      #f5f5f0;
    --rule:       #c8d8db;
    --white:      #ffffff;
    --red:        #a4161a;
    --red-light:  #fdecea;
    --green:      #1c6b3a;
    --green-light:#e2f5ea;
    --mid:        #5c6b73;
    --gold:       #b45309;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--smoke);
    color: var(--ink);
    font-size: 10pt;
    line-height: 1.45;
  }

  .page {
    max-width: 8.5in;
    margin: 0 auto;
    background: var(--white);
    padding: 0.38in 0.5in 0.35in;
    min-height: 11in;
  }

  /* ── HEADER ── */
  .header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 14px;
    align-items: end;
    padding-bottom: 9px;
    margin-bottom: 9px;
    border-bottom: 4px double var(--teal);
  }
  .firm-eyebrow {
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 2px;
  }
  .doc-title {
    font-family: 'DM Serif Display', serif;
    font-size: 22pt;
    color: var(--ink);
    line-height: 1.05;
    margin: 2px 0;
  }
  .doc-subtitle {
    font-size: 8.5pt;
    color: var(--mid);
    font-weight: 300;
    margin-top: 2px;
  }
  .header-pill {
    background: var(--teal);
    color: var(--white);
    padding: 8px 13px;
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.7;
    white-space: nowrap;
  }
  .header-pill span {
    display: block;
    color: #a8dde5;
    font-style: italic;
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0;
    font-size: 8.5pt;
  }

  /* ── PURPOSE BAND ── */
  .purpose {
    background: var(--amber-light);
    border-left: 4px solid var(--amber);
    padding: 6px 11px;
    font-size: 8pt;
    color: #5a3a00;
    margin-bottom: 9px;
    line-height: 1.55;
  }
  .purpose strong { color: var(--gold); font-weight: 700; }

  /* ── INTAKE ── */
  .intake {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px 12px;
    background: var(--teal-light);
    border-left: 5px solid var(--teal);
    padding: 8px 11px;
    margin-bottom: 10px;
  }
  .f label {
    font-size: 6.5pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--teal);
    display: block;
    margin-bottom: 1px;
  }
  .f input {
    width: 100%;
    border: none;
    border-bottom: 1.5px solid var(--teal);
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 9pt;
    color: var(--ink);
    padding: 1px 0;
    outline: none;
  }
  .f input:focus { border-bottom-color: var(--amber); }

  /* ── SECTION HEADER ── */
  .sec-head {
    display: flex;
    align-items: center;
    background: var(--teal);
    color: var(--white);
    padding: 4px 10px;
    gap: 7px;
    margin-bottom: 4px;
  }
  .sec-letter {
    font-family: 'DM Serif Display', serif;
    font-size: 14pt;
    color: #a8dde5;
    min-width: 18px;
    line-height: 1;
  }
  .sec-name { font-size: 8pt; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .sec-who  { margin-left: auto; font-size: 6.5pt; color: #a8dde5; font-style: italic; }

  /* ── SCAN TABLE ── */
  .scan-table { width: 100%; border-collapse: collapse; margin-bottom: 9px; }
  .scan-table th {
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--teal);
    background: var(--teal-light);
    padding: 3.5px 7px;
    text-align: left;
    border: 1px solid var(--rule);
  }
  .scan-table td {
    font-size: 8.5pt;
    padding: 3.5px 7px;
    border: 1px solid var(--rule);
    vertical-align: top;
  }
  .scan-table tr:nth-child(even) td { background: #f7fbfc; }

  .col-chk  { width: 3%; text-align: center; }
  .col-item { width: 43%; }
  .col-yn   { width: 9%; text-align: center; }
  .col-stat { width: 14%; }
  .col-tlf  { width: 31%; }

  .col-chk input[type="checkbox"] { accent-color: var(--teal); width: 12px; height: 12px; }

  .it-main { line-height: 1.35; font-size: 8.5pt; }
  .it-sub  { font-size: 7pt; color: var(--mid); margin-top: 1px; }
  .it-flag { font-size: 7pt; color: var(--red); font-weight: 700; margin-top: 1px; }

  .yn-wrap { display: flex; gap: 8px; justify-content: center; align-items: center; }
  .yn-wrap label { font-size: 7.5pt; color: var(--mid); }
  .yn-wrap input[type="radio"] { accent-color: var(--teal); }

  .stat-sel {
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 7.5pt;
    border: 1px solid var(--rule);
    padding: 2px 3px;
    outline: none;
    background: var(--white);
    color: var(--ink);
  }

  /* Service tag chips */
  .tlf-tags { display: flex; flex-wrap: wrap; gap: 3px; }
  .tag {
    font-size: 6.5pt;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: 1px;
    white-space: nowrap;
  }
  .tag-tv   { background: var(--amber-light); color: var(--gold); border: 1px solid #fcd34d; }
  .tag-ss   { background: #fde8ff; color: #6b21a8; border: 1px solid #d8b4fe; }
  .tag-ai   { background: #dbeafe; color: #1e3a8a; border: 1px solid #93c5fd; }
  .tag-ewa  { background: var(--green-light); color: var(--green); border: 1px solid #86efac; }

  /* ── LEGEND ── */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    align-items: center;
    background: var(--smoke);
    border: 1px solid var(--rule);
    padding: 5px 10px;
    margin-bottom: 9px;
    font-size: 7pt;
  }
  .legend-label { font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--teal); margin-right: 4px; }
  .legend-item { display: flex; align-items: center; gap: 4px; }

  /* ── TWO-COL BOTTOM ── */
  .bottom { display: grid; grid-template-columns: 1.15fr 1fr; gap: 9px; margin-top: 8px; }

  /* Readiness meter */
  .meter-box { border: 1px solid var(--rule); padding: 8px 10px; }
  .meter-box h4 {
    font-size: 7pt; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.09em; color: var(--teal);
    border-bottom: 1px solid var(--rule); padding-bottom: 3px; margin-bottom: 7px;
  }

  .meter-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; margin-bottom: 7px; }
  .m-cell {
    border: 1.5px solid var(--rule);
    padding: 5px 4px;
    text-align: center;
    cursor: pointer;
  }
  .m-cell:has(input:checked) { border-color: var(--teal); background: var(--teal-light); }
  .m-cell:has(input:checked) .m-label { color: var(--teal); }
  .m-cell input[type="radio"] { display: none; }
  .m-label { font-size: 7.5pt; font-weight: 700; display: block; cursor: pointer; }
  .m-desc  { font-size: 6.5pt; color: var(--mid); display: block; margin-top: 2px; line-height: 1.35; }

  .priority-list { margin-top: 5px; }
  .priority-list p { font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--teal); margin-bottom: 4px; }
  .p-row { display: grid; grid-template-columns: 14px 1fr; gap: 4px; align-items: start; padding: 2.5px 0; border-bottom: 1px dashed #d5e4e7; font-size: 8pt; }
  .p-row:last-child { border-bottom: none; }
  .p-row input[type="checkbox"] { accent-color: var(--teal); margin-top: 1px; }
  .p-row input[type="text"] {
    width: 100%; border: none; border-bottom: 1px solid var(--rule);
    font-size: 7.5pt; font-family: 'DM Sans', sans-serif;
    background: transparent; outline: none; color: var(--mid);
  }

  /* Notes panel */
  .notes-panel { border: 1px solid var(--rule); padding: 8px 10px; }
  .notes-panel h4 {
    font-size: 7pt; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.09em; color: var(--teal);
    border-bottom: 1px solid var(--rule); padding-bottom: 3px; margin-bottom: 6px;
  }
  .notes-panel textarea {
    width: 100%; height: 72px;
    border: none; background: var(--smoke);
    font-family: 'DM Sans', sans-serif; font-size: 8.5pt;
    padding: 4px 6px; resize: none; outline: none; color: var(--ink);
    margin-bottom: 6px;
  }
  .notes-panel textarea:focus { outline: 1px solid var(--teal); }

  /* Recommended services checklist */
  .svc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px 10px; }
  .svc-item { display: flex; align-items: center; gap: 5px; font-size: 7.5pt; padding: 1.5px 0; }
  .svc-item input[type="checkbox"] { accent-color: var(--teal); flex-shrink: 0; }
  .svc-dot { width: 8px; height: 8px; flex-shrink: 0; }

  /* ── SIG ROW ── */
  .sig-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-top: 9px;
    padding-top: 7px;
    border-top: 2px double var(--teal);
  }
  .sig-f label {
    font-size: 6.5pt; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--mid); display: block; margin-bottom: 2px;
  }
  .sig-f input {
    width: 100%; border: none; border-bottom: 1.5px solid var(--rule);
    background: transparent; font-family: 'DM Sans', sans-serif;
    font-size: 9.5pt; padding: 1px 0; outline: none;
  }
  .sig-f input:focus { border-bottom-color: var(--teal); }

  /* ── FOOTER ── */
  .footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 9px; padding-top: 6px;
    border-top: 2px double var(--teal);
    font-size: 7pt; color: var(--mid);
  }
  .footer-brand { color: var(--teal); font-weight: 700; }

  @media print {
    body { background: white; }
    .page { margin: 0; padding: 0.35in 0.46in; }
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>
