<div class="page">

  <!-- HEADER -->
  <div class="header">
    <div>
      <div class="firm-eyebrow">The Language Firm · languagefirm.org</div>
      <div class="doc-title">AI Readiness Scan</div>
      <div class="doc-subtitle">K–12 Districts · Rapid Self-Assessment · Policy, Data Protection, Language Access &amp; Staff Readiness · Tool Vault Diagnostic</div>
    </div>
    <div class="header-pill">
      K–12 TOOLKIT
      <span>AI Governance Series</span>
    </div>
  </div>

  <!-- PURPOSE -->
  <div class="purpose">
    <strong>How to use:</strong> Complete this scan before adopting any AI tool, prior to a monitoring visit, or during annual technology review. Each item maps to a Language Firm service so you know exactly where to focus and what support is available. A "No" or "Partial" on any item signals a gap that may affect federal compliance.
  </div>

  <!-- INTAKE -->
  <div class="intake">
    <div class="f"><label>District / School Name</label><input type="text" placeholder="Full legal name"></div>
    <div class="f"><label>Completing This Scan</label><input type="text" placeholder="Name &amp; title"></div>
    <div class="f"><label>Current AI Tools in Use</label><input type="text" placeholder="List or 'none identified'"></div>
    <div class="f"><label>Scan Date</label><input type="text" placeholder="mm/dd/yyyy"></div>
  </div>

  <!-- SERVICE TAG LEGEND -->
  <div class="legend">
    <span class="legend-label">TLF Service Key →</span>
    <div class="legend-item"><span class="tag tag-tv">Tool Vault</span><span>Weekly AI incident intel &amp; tool research (Bulletin + District Filing)</span></div>
    <div class="legend-item"><span class="tag tag-ss">SSES</span><span>Scope &amp; Sequence Evidence System — curriculum alignment &amp; AI guardrails</span></div>
    <div class="legend-item"><span class="tag tag-ai">AI &amp; DataGuard</span><span>AI governance, student data privacy &amp; federal compliance packages</span></div>
    <div class="legend-item"><span class="tag tag-ewa">EWA Maintenance Core</span><span>Recurring evidence workflow build &amp; audit-readiness upkeep</span></div>
  </div>

  <!-- SECTION A -->
  <div class="sec-head">
    <span class="sec-letter">A</span>
    <span class="sec-name">Policy &amp; Governance — Does the District Have the Basics in Place?</span>
    <span class="sec-who">Curriculum Director / Superintendent</span>
  </div>
  <table class="scan-table">
    <thead>
      <tr>
        <th class="col-chk">✓</th>
        <th class="col-item">Scan Item</th>
        <th class="col-yn" colspan="2">Yes / No / Partial</th>
        <th class="col-stat">Status</th>
        <th class="col-tlf">If "No" or "Partial" → TLF Can Help</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">Board-adopted AI Use Policy (or interim policy) exists and is current</div><div class="it-sub">Covers staff use, student use, and content generated for official purposes</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="a1" id="a1y"><label for="a1y">Yes</label>
            <input type="radio" name="a1" id="a1p"><label for="a1p">Part.</label>
            <input type="radio" name="a1" id="a1n"><label for="a1n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ In Place</option><option>⚠ Draft Only</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-ai">AI &amp; DataGuard</span><span class="tag tag-ewa">EWA Maintenance Core</span></div></td>
      </tr>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">Acceptable Use Policy (AUP) updated to address AI tools explicitly</div><div class="it-sub">Students and parents notified; available in community languages</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="a2" id="a2y"><label for="a2y">Yes</label>
            <input type="radio" name="a2" id="a2p"><label for="a2p">Part.</label>
            <input type="radio" name="a2" id="a2n"><label for="a2n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ In Place</option><option>⚠ Draft Only</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-ai">AI &amp; DataGuard</span><span class="tag tag-ss">SSES</span></div></td>
      </tr>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">Designated staff role or committee responsible for AI tool review and approval</div><div class="it-sub">No open-door adoption — someone owns the vetting process</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="a3" id="a3y"><label for="a3y">Yes</label>
            <input type="radio" name="a3" id="a3p"><label for="a3p">Part.</label>
            <input type="radio" name="a3" id="a3n"><label for="a3n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ In Place</option><option>⚠ Draft Only</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-tv">Tool Vault</span><span class="tag tag-ai">AI &amp; DataGuard</span></div></td>
      </tr>
    </tbody>
  </table>

  <!-- SECTION B -->
  <div class="sec-head">
    <span class="sec-letter">B</span>
    <span class="sec-name">Student Data &amp; Federal Compliance — Are Students Protected?</span>
    <span class="sec-who">Tech Director / Federal Programs Coordinator</span>
  </div>
  <table class="scan-table">
    <thead>
      <tr>
        <th class="col-chk">✓</th>
        <th class="col-item">Scan Item</th>
        <th class="col-yn" colspan="2">Yes / No / Partial</th>
        <th class="col-stat">Status</th>
        <th class="col-tlf">If "No" or "Partial" → TLF Can Help</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">Every AI tool used with student data has an executed DPA on file</div><div class="it-flag">⚑ Audit red flag: tools without DPAs are a FERPA violation waiting to happen</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="b1" id="b1y"><label for="b1y">Yes</label>
            <input type="radio" name="b1" id="b1p"><label for="b1p">Part.</label>
            <input type="radio" name="b1" id="b1n"><label for="b1n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ Verified</option><option>⚠ Pending</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-tv">Tool Vault</span><span class="tag tag-ewa">EWA Maintenance Core</span></div></td>
      </tr>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">No AI vendor uses student inputs to train its model (confirmed in contract)</div><div class="it-sub">Inferred or implied language is not sufficient — must be explicit</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="b2" id="b2y"><label for="b2y">Yes</label>
            <input type="radio" name="b2" id="b2p"><label for="b2p">Part.</label>
            <input type="radio" name="b2" id="b2n"><label for="b2n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ Verified</option><option>⚠ Pending</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-tv">Tool Vault</span></div></td>
      </tr>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">AI tools purchased with federal funds (Title I / III / IDEA / ESSER) verified as allowable</div><div class="it-sub">Supplement-not-supplant documented; funding source matched to approved use</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="b3" id="b3y"><label for="b3y">Yes</label>
            <input type="radio" name="b3" id="b3p"><label for="b3p">Part.</label>
            <input type="radio" name="b3" id="b3n"><label for="b3n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ Verified</option><option>⚠ Pending</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-ai">AI &amp; DataGuard</span><span class="tag tag-ewa">EWA Maintenance Core</span></div></td>
      </tr>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">AI-generated content in grant reports, APRs, or federal submissions reviewed by staff before filing</div><div class="it-flag">⚑ Unverified AI output in federal submissions = material misrepresentation risk</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="b4" id="b4y"><label for="b4y">Yes</label>
            <input type="radio" name="b4" id="b4p"><label for="b4p">Part.</label>
            <input type="radio" name="b4" id="b4n"><label for="b4n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ Process Set</option><option>⚠ Informal</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-ewa">EWA Maintenance Core</span><span class="tag tag-ai">AI &amp; DataGuard</span></div></td>
      </tr>
    </tbody>
  </table>

  <!-- SECTION C -->
  <div class="sec-head">
    <span class="sec-letter">C</span>
    <span class="sec-name">Language Access &amp; Equity — Do AI Tools Work for All Families?</span>
    <span class="sec-who">EL / Title III Coordinator</span>
  </div>
  <table class="scan-table">
    <thead>
      <tr>
        <th class="col-chk">✓</th>
        <th class="col-item">Scan Item</th>
        <th class="col-yn" colspan="2">Yes / No / Partial</th>
        <th class="col-stat">Status</th>
        <th class="col-tlf">If "No" or "Partial" → TLF Can Help</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="col-chk"><input type="checkbox"></td>
        <td><div class="it-main">AI tools used with EL students or families available in languages spoken by district communities</div><div class="it-sub">Title VI / Title III — inaccessible tools create a civil-rights exposure</div></td>
        <td colspan="2">
          <div class="yn-wrap">
            <input type="radio" name="c1" id="c1y"><label for="c1y">Yes</label>
            <input type="radio" name="c1" id="c1p"><label for="c1p">Part.</label>
            <input type="radio" name="c1" id="c1n"><label for="c1n">No</label>
          </div>
        </td>
        <td><select class="stat-sel"><option value="">—</option><option>✓ Verified</option><option>⚠ Partial</option><option>✗ Gap</option></select></td>
        <td><div class="tlf-tags"><span class="tag tag-ss">SSES</span><span class="tag tag-ai">AI &amp; DataGuard</span></div></td>
