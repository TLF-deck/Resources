<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Compliance Certification — East Side Spring Middle School</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --dark:      #1B3A4B;
    --accent:    #1A5FA0;
    --amber:     #A85D1A;
    --green:     #2E5E4A;
    --green-bg:  #D4EDE4;
    --amber-bg:  #F5E0C8;
    --blue-bg:   #D4E6F5;
    --purple:    #4A2E7A;
    --purple-bg: #EDE4F5;
    --gray:      #6B7C8A;
    --gray-lt:   #E8EDF1;
    --body:      #333333;
    --bg:        #F2F4F6;
    --white:     #FFFFFF;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); font-family: 'DM Sans', sans-serif; color: var(--body); line-height: 1.6; }
  .wrap { max-width: 860px; margin: 0 auto; padding: 40px 24px 64px; }
 
  .verified-strip {
    background: var(--green); border-radius: 6px;
    padding: 18px 24px; display: flex; align-items: center; gap: 14px;
    margin-bottom: 28px; animation: fadeUp 0.4s ease both;
  }
  .verified-check {
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,255,255,0.15); border: 1.5px solid rgba(255,255,255,0.35);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .verified-check svg { width: 18px; height: 18px; }
  .verified-label { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 700; color: var(--white); line-height: 1.2; }
  .verified-sub { font-size: 12.5px; color: rgba(255,255,255,0.7); font-weight: 400; margin-top: 2px; }
  .verified-ts { margin-left: auto; font-size: 11px; color: rgba(255,255,255,0.55); text-align: right; line-height: 1.5; flex-shrink: 0; }
 
  .page-eyebrow {
    font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); display: flex; align-items: center; gap: 10px;
    margin-bottom: 10px; animation: fadeUp 0.4s ease both 0.05s;
  }
  .page-eyebrow::before { content: ''; display: inline-block; width: 22px; height: 2px; background: var(--accent); }
  .page-title {
    font-family: 'Fraunces', serif; font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 700; color: var(--dark); line-height: 1.15; margin-bottom: 8px;
    animation: fadeUp 0.4s ease both 0.08s;
  }
  .page-title em { font-style: italic; font-weight: 300; color: var(--accent); }
  .page-url {
    font-size: 12px; color: var(--gray); font-family: monospace;
    background: var(--white); display: inline-block; padding: 5px 12px;
    border-radius: 3px; border: 1px solid var(--gray-lt); margin-bottom: 28px;
    animation: fadeUp 0.4s ease both 0.1s;
  }
 
  .school-card {
    background: var(--white); border-radius: 6px; border-left: 5px solid var(--accent);
    box-shadow: 0 1px 6px rgba(27,58,75,0.07); padding: 22px 26px;
    display: flex; align-items: flex-start; gap: 20px;
    margin-bottom: 20px; animation: fadeUp 0.4s ease both 0.12s;
  }
  .school-avatar {
    width: 52px; height: 52px; border-radius: 6px; background: var(--blue-bg);
    border: 1px solid rgba(26,95,160,0.2); display: flex; align-items: center;
    justify-content: center; font-family: 'Fraunces', serif;
    font-size: 16px; font-weight: 700; color: var(--accent); flex-shrink: 0;
  }
  .school-tag {
    display: inline-block; margin-bottom: 5px;
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
    padding: 3px 9px; border-radius: 2px;
    background: var(--purple-bg); color: var(--purple);
    border: 1px solid rgba(74,46,122,0.2);
  }
  .school-name { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 700; color: var(--dark); line-height: 1.2; margin-bottom: 4px; }
  .school-meta { font-size: 13px; color: var(--gray); line-height: 1.6; }
  .school-badge-wrap { margin-left: auto; flex-shrink: 0; }
 
  .record-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 10px; margin-bottom: 20px;
    animation: fadeUp 0.4s ease both 0.15s;
  }
  .record-cell {
    background: var(--white); border-radius: 6px;
    border: 1px solid var(--gray-lt); padding: 14px 16px;
    box-shadow: 0 1px 4px rgba(27,58,75,0.05);
  }
  .record-key { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--gray); margin-bottom: 5px; }
  .record-val { font-family: 'Fraunces', serif; font-size: 15px; font-weight: 600; color: var(--dark); line-height: 1.2; }
  .record-val.green { color: var(--green); }
  .record-val.mono { font-family: monospace; font-size: 12.5px; font-weight: 400; color: var(--gray); }
 
  .section-label {
    font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
    color: var(--gray); padding: 6px 0; border-bottom: 1px solid var(--gray-lt);
    margin-bottom: 16px; margin-top: 8px;
  }
 
  .cert-item {
    background: var(--white); border-radius: 6px;
    box-shadow: 0 1px 6px rgba(27,58,75,0.07); overflow: hidden;
    margin-bottom: 12px; animation: fadeUp 0.4s ease both;
  }
  .cert-item.met   { border-left: 5px solid var(--green); }
  .cert-item.scope { border-left: 5px solid var(--amber); }
  .cert-inner { padding: 18px 22px; }
  .cert-top { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
  .cert-badge { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 10px; border-radius: 2px; flex-shrink: 0; margin-top: 2px; }
  .cert-item.met   .cert-badge { background: var(--green-bg); color: var(--green); }
  .cert-item.scope .cert-badge { background: var(--amber-bg); color: var(--amber); }
  .cert-title { font-family: 'Fraunces', serif; font-size: 16px; font-weight: 700; color: var(--dark); line-height: 1.25; }
  .cert-body { font-size: 13.5px; color: #555; line-height: 1.65; }
 
  .cal-context {
    background: var(--white); border-left: 4px solid var(--purple);
    border-radius: 0 6px 6px 0; padding: 16px 20px; margin-bottom: 20px;
    font-size: 13.5px; color: var(--gray); line-height: 1.65;
    animation: fadeUp 0.4s ease both 0.18s;
  }
  .cal-context strong { color: var(--dark); }
 
  .statbar { display: flex; background: var(--dark); border-radius: 6px; overflow: hidden; margin-top: 32px; animation: fadeUp 0.5s ease both 0.25s; }
  .stat { flex: 1; padding: 20px 24px; border-right: 1px solid rgba(255,255,255,0.1); }
  .stat:last-child { border-right: none; }
  .stat-val { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .stat-lbl { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.4; }
 
  .actions { display: flex; gap: 10px; margin-top: 24px; flex-wrap: wrap; animation: fadeUp 0.4s ease both 0.22s; }
  .btn {
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.3px;
    padding: 10px 18px; border-radius: 3px; border: 2px solid var(--dark);
    background: var(--dark); color: var(--white); cursor: pointer; transition: background 0.15s, opacity 0.15s;
  }
  .btn:hover { background: #244d62; }
  .btn.outline { background: var(--white); color: var(--dark); }
  .btn.outline:hover { background: var(--gray-lt); }
  .btn.success { background: var(--green); border-color: var(--green); }
 
  .toast {
    position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(12px);
    background: var(--dark); color: var(--white);
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
    padding: 10px 20px; border-radius: 4px;
    opacity: 0; transition: opacity 0.2s, transform 0.2s;
    pointer-events: none; white-space: nowrap; z-index: 999;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
 
  .footer-note {
    margin-top: 28px; padding: 18px 22px; background: var(--white); border-radius: 6px;
    border-left: 4px solid var(--amber); font-size: 13px; color: var(--gray); line-height: 1.65;
    animation: fadeUp 0.5s ease both 0.28s;
  }
  .footer-note strong { color: var(--dark); }
 
  /* Hidden SVG badge used for download */
  #badge-source { position: absolute; left: -9999px; top: -9999px; }
 
  @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
 
  @media print {
    body { background: white; }
    .actions, .toast { display: none; }
    .wrap { padding: 20px; }
    .verified-strip { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .statbar { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .school-tag { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .cert-item.met, .cert-item.scope { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .cal-context { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .footer-note { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    * { animation: none !important; }
  }
 
  @media (max-width: 600px) {
    .record-grid { grid-template-columns: 1fr 1fr; }
    .school-badge-wrap { display: none; }
    .statbar { flex-direction: column; }
    .stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .stat:last-child { border-bottom: none; }
    .actions { flex-direction: column; }
    .btn { text-align: center; }
  }
</style>
</head>
<body>
 
