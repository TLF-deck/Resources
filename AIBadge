<script>
  // ── TOAST helper ──
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2400);
  }
 
  // ── COPY URL ──
  function copyURL() {
    const url = 'https://verify.languagefirm.org/cert/ESS-2026-07134';
    const btn = document.getElementById('btn-copy');
    navigator.clipboard.writeText(url).then(() => {
      btn.textContent = 'Copied!';
      btn.classList.add('success');
      showToast('Verification URL copied to clipboard');
      setTimeout(() => {
        btn.textContent = 'Copy verification URL';
        btn.classList.remove('success');
      }, 2200);
    }).catch(() => {
      // fallback for older browsers
      const ta = document.createElement('textarea');
      ta.value = url;
      ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast('Verification URL copied to clipboard');
    });
  }
 
  // ── PRINT ──
  function printRecord() {
    window.print();
  }
 
  // ── DOWNLOAD BADGE (SVG + PNG via canvas) ──
  function downloadBadge() {
    const btn = document.getElementById('btn-download');
    btn.textContent = 'Preparing...';
    btn.disabled = true;
 
    // 1. Download SVG file
    const svgEl = document.getElementById('badge-source');
    const svgData = new XMLSerializer().serializeToString(svgEl);
    const svgBlob = new Blob([svgData], { type: 'image/svg+xml;charset=utf-8' });
    const svgURL = URL.createObjectURL(svgBlob);
    const svgLink = document.createElement('a');
    svgLink.href = svgURL;
    svgLink.download = 'ESS-2026-badge.svg';
    svgLink.click();
    URL.revokeObjectURL(svgURL);
 
    // 2. Download PNG via canvas (slight delay so both downloads register)
    setTimeout(() => {
      const canvas = document.createElement('canvas');
      canvas.width = 400;
      canvas.height = 440;
      const ctx = canvas.getContext('2d');
      const img = new Image();
      const svgBlob2 = new Blob([svgData], { type: 'image/svg+xml;charset=utf-8' });
      const url2 = URL.createObjectURL(svgBlob2);
      img.onload = function() {
        ctx.drawImage(img, 0, 0, 400, 440);
        URL.revokeObjectURL(url2);
        const pngLink = document.createElement('a');
        pngLink.download = 'ESS-2026-badge.png';
        pngLink.href = canvas.toDataURL('image/png');
        pngLink.click();
        btn.textContent = 'Downloaded!';
        btn.classList.add('success');
        showToast('SVG + PNG downloaded — check your downloads folder');
        setTimeout(() => {
          btn.textContent = 'Download badge assets';
          btn.classList.remove('success');
          btn.disabled = false;
        }, 2400);
      };
      img.onerror = function() {
        // SVG-to-canvas can fail in some browsers due to CORS on fonts
        // Fall back to SVG only with a note
        showToast('SVG downloaded — PNG unavailable in this browser');
        btn.textContent = 'Download badge assets';
        btn.classList.remove('success');
        btn.disabled = false;
      };
      img.src = url2;
    }, 400);
  }
</script>
